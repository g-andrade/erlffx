% -*- mode: erlang; -*- vim: set ft=erlang:
[
    {config, [
        #{
            files => ["src/**/*.erl"],
            ruleset => erl_files
        },
        #{
            files => ["test/**/*.erl"],
            ruleset => erl_files,
            % The known-answer test vectors are intentionally repetitive and
            % carry unavoidably long literals (256-bit keys, digit lists).
            rules => [
                {elvis_style, dont_repeat_yourself, disable},
                {elvis_text_style, max_line_length, disable}
            ]
        },
        #{
            files => ["rebar.config", "elvis.config"],
            ruleset => rebar_config
        }
    ]}
].
